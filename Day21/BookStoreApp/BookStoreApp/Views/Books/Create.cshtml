@model Book

<h2>Add Book</h2>

<form method="post">
    <label>Title</label>
    <input type="text" name="Title" />

    <label>Author</label>
    <input type="text" name="Author" />

    <label>Price</label>
    <input type="number" step="0.01" name="Price" />

    <button type="submit">Save</button>
</form>
